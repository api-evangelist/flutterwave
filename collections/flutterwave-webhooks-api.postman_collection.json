              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "disabled": false,
                "description": "(Required) Pre-shared secret hash configured by the merchant.",
                "key": "verif-hash",
                "value": "<string>"
